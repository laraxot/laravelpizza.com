# Cursor MCP Configuration for LaravelPizza Project

# Enable file search and navigation
enable_search: true
enable_navigation: true

# File patterns to include/exclude
include_patterns:
  - "**/*.php"
  - "**/*.blade.php"
  - "**/*.css"
  - "**/*.js"
  - "**/*.json"
  - "**/*.md"
  - "**/*.env"

exclude_patterns:
  - "**/vendor/**"
  - "**/node_modules/**"
  - "**/storage/**"
  - "**/bootstrap/cache/**"
  - "**/tests/**"
  - "**/docs/**"
  - "**/.git/**"

# PHP-specific settings
php:
  enable_type_checking: true
  enable_code_completion: true
  enable_refactoring: true

# Frontend settings
frontend:
  enable_hot_reload: true
  enable_css_processing: true
  enable_js_processing: true

# Database settings
database:
  enable_schema_exploration: true
  enable_migration_tracking: true

# Git settings
git:
  enable_commit_assistance: true
  enable_branch_management: true
  enable_merge_assistance: true

# Testing settings
testing:
  enable_test_discovery: true
  enable_test_execution: true
  enable_coverage_reporting: true

# Documentation settings
documentation:
  enable_doc_generation: true
  enable_api_docs: true
  enable_readme_generation: true

# Security settings
security:
  enable_vulnerability_scanning: true
  enable_code_quality_checks: true
  enable_dependency_analysis: true

# Performance settings
performance:
  enable_benchmarking: true
  enable_profiling: true
  enable_caching_analysis: true

# Debug settings
debug:
  enable_step_through: true
  enable_breakpoints: true
  enable_variable_inspection: true
