<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
            <directory>Modules/*/tests/Unit</directory>
            <directory>Modules/*/tests/Traits</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
            <directory>Modules/*/tests/Feature</directory>
            <directory>Modules/*/tests/Integration</directory>
            <directory>Modules/*/tests/Performance</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>Modules/*/app</directory>
        </include>
        <exclude>
            <directory>app/Resources</directory>
            <directory>bootstrap</directory>
            <directory>config</directory>
            <directory>database</directory>
            <directory>lang</directory>
            <directory>public</directory>
            <directory>resources</directory>
            <directory>routes</directory>
            <directory>storage</directory>
            <directory>tests</directory>
            <directory>vendor</directory>
            <directory>Modules/Xot/app/Resources</directory>
            <directory>Modules/Xot/app/Routes</directory>
            <directory>Modules/Xot/app/Contracts</directory>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- CRITICAL: Force test DB - PHPUnit sets these BEFORE app bootstrap.
             Laravel may load .env instead of .env.testing depending on bootstrap order.
             Without these, TenantServiceProvider uses laravelpizza_data (prod) for activity/user connections. -->
        <env name="DB_DATABASE" value="laravelpizza_data_test"/>
        <env name="DB_DATABASE_USER" value="laravelpizza_user_test"/>
        <env name="DB_DATABASE_ACTIVITY" value="laravelpizza_data_test"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <!-- Use mysql so activity_log (migrated on default) is available in tests -->
        <env name="ACTIVITY_LOGGER_DB_CONNECTION" value="mysql"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
