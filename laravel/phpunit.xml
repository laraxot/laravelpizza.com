<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Modules">
            <directory>Modules/Activity/tests</directory>
            <directory>Modules/Cms/tests</directory>
            <directory>Modules/Gdpr/tests</directory>
            <directory>Modules/Geo/tests</directory>
            <directory>Modules/Job/tests</directory>
            <directory>Modules/Lang/tests</directory>
            <directory>Modules/Media/tests</directory>
            <directory>Modules/Meetup/tests</directory>
            <directory>Modules/Notify/tests</directory>
            <directory>Modules/Seo/tests</directory>
            <directory>Modules/Tenant/tests</directory>
            <directory>Modules/UI/tests</directory>
            <directory>Modules/User/tests</directory>
            <directory>Modules/Xot/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>Modules/Activity/app</directory>
            <directory>Modules/Cms/app</directory>
            <directory>Modules/Gdpr/app</directory>
            <directory>Modules/Geo/app</directory>
            <directory>Modules/Job/app</directory>
            <directory>Modules/Lang/app</directory>
            <directory>Modules/Media/app</directory>
            <directory>Modules/Meetup/app</directory>
            <directory>Modules/Notify/app</directory>
            <directory>Modules/Seo/app</directory>
            <directory>Modules/Tenant/app</directory>
            <directory>Modules/UI/app</directory>
            <directory>Modules/User/app</directory>
            <directory>Modules/Xot/app</directory>
        </include>
        <exclude>
            <directory suffix=".php">./Modules/*/config</directory>
            <directory suffix=".php">./Modules/*/database</directory>
            <directory suffix=".php">./Modules/*/resources</directory>
            <directory suffix=".php">./Modules/*/routes</directory>
            <directory suffix=".php">./Modules/*/tests</directory>
            <directory suffix=".php">./Modules/*/.vscode</directory>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- CRITICAL: Force test DB - PHPUnit sets these BEFORE app bootstrap.
             Laravel may load .env instead of .env.testing depending on bootstrap order.
             Without these, TenantServiceProvider uses laravelpizza_data (prod) for activity/user connections. -->
        <env name="DB_DATABASE" value="laravelpizza_data_test"/>
        <env name="DB_DATABASE_USER" value="laravelpizza_user_test"/>
        <env name="DB_DATABASE_ACTIVITY" value="laravelpizza_data_test"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="ACTIVITY_LOGGER_DB_CONNECTION" value="activity"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
