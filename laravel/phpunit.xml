<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Modules">
            <directory suffix="Test.php">./Modules/*/tests/Feature</directory>
            <directory suffix="Test.php">./Modules/*/tests/Unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">./Modules/*/app/Actions</directory>
            <directory suffix=".php">./Modules/*/app/Models</directory>
            <directory suffix=".php">./Modules/*/app/Services</directory>
            <directory suffix=".php">./Modules/*/app/Traits</directory>
            <directory suffix=".php">./Modules/*/app/Providers</directory>
            <directory suffix=".php">./Modules/*/app/Contracts</directory>
            <directory suffix=".php">./Modules/*/app/Exceptions</directory>
            <directory suffix=".php">./Modules/*/app/Enums</directory>
            <directory suffix=".php">./Modules/*/app/Transformers</directory>
            <directory suffix=".php">./Modules/*/app/Datas</directory>
            <directory suffix=".php">./Modules/*/app/DataTransferObjects</directory>
            <directory suffix=".php">./app</directory>
        </include>
        <exclude>
            <file>./Modules/*/app/Actions/.php-cs-fixer.dist.php</file>
            <file>./Modules/*/app/Actions/.gitkeep</file>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- CRITICAL: Force test DB - PHPUnit sets these BEFORE app bootstrap.
             Laravel may load .env instead of .env.testing depending on bootstrap order.
             Without these, TenantServiceProvider uses laravelpizza_data (prod) for activity/user connections. -->
        <env name="DB_DATABASE" value="laravelpizza_data_test"/>
        <env name="DB_DATABASE_USER" value="laravelpizza_user_test"/>
        <env name="DB_DATABASE_ACTIVITY" value="laravelpizza_data_test"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <!-- Use mysql so activity_log (migrated on default) is available in tests -->
        <env name="ACTIVITY_LOGGER_DB_CONNECTION" value="mysql"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
