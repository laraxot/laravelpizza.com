{
    "name": "laraxot/module_activity_fila5",
    "description": "Activity logging and event sourcing module for the Laraxot ecosystem: audit trail, user actions tracking, and CQRS event store.",
    "keywords": [
        "laraxot",
        "laravel",
        "filament",
        "module_activity",
        "activity-log",
        "event-sourcing",
        "audit-trail",
        "cqrs",
        "spatie-activitylog"
    ],
    "homepage": "https://github.com/laraxot/module_activity_fila5",
    "license": "MIT",
    "authors": [
        {
            "name": "Marco Sottana",
            "email": "marco.sottana@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Activity\\Providers\\ActivityServiceProvider",
                "Modules\\Activity\\Providers\\Filament\\AdminPanelProvider"
            ],
            "aliases": []
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Activity\\": "app/",
            "Modules\\Activity\\Database\\Factories\\": "database/factories/",
            "Modules\\Activity\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Activity\\Tests\\": "tests/"
        }
    },
    "require": {
        "spatie/laravel-activitylog": "*",
        "spatie/laravel-event-sourcing": "*"
    },
    "require-dev": {},
    "repositories_comment": [
        {
            "type": "path",
            "url": "../Xot"
        },
        {
            "type": "path",
            "url": "../Tenant"
        },
        {
            "type": "path",
            "url": "../UI"
        }
    ],
    "scripts": {
        "post-autoload-dump": [],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "./vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve"
        ],
        "lint": [
            "@php vendor/bin/pint",
            "@php vendor/bin/phpstan analyse"
        ]
    },
    "config": {
        "_comment_vendor-dir": "../../vendor",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
