{
  "name": "Activity",
  "type": "module",
  "status": "baseline",
  "purpose": "Tracciare attivita, eventi e audit trail applicativi per utenti, operatori e sistema.",
  "goals": [
    "Registrare eventi significativi",
    "Offrire superfici di consultazione e audit",
    "Supportare troubleshooting e accountability"
  ],
  "nonGoals": [
    "Sostituire il dominio applicativo",
    "Gestire forecasting o settlement"
  ],
  "dependencies": [
    "User",
    "Xot"
  ],
  "qualityGates": [
    "./vendor/bin/phpstan analyse Modules/Activity",
    "./vendor/bin/phpinsights analyse Modules/Activity --min-quality=0 --min-complexity=0 --min-architecture=0 --min-style=0"
  ],
  "suiteVersion": "baseline-v1",
  "sourceFramework": "Notion product template family adapted to repository governance",
  "companionDocs": [
    "product-roadmap.md",
    "product-launch-plan.md",
    "product-strategy.md",
    "user-research.md",
    "sprint-planning-meeting.md"
  ],
  "implementationPattern": "action-first",
  "actionStandard": "spatie/laravel-queueable-action",
  "architectureRule": "No generic Services for business logic; use Action classes with execute()"
}
