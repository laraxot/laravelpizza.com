{
  "name": "Notify",
  "type": "module",
  "status": "baseline",
  "purpose": "Gestire notifiche, template mail e messaggistica operativa del sistema.",
  "goals": [
    "Inviare notifiche affidabili",
    "Rendere i template gestibili in admin",
    "Supportare workflow applicativi cross-modulo"
  ],
  "nonGoals": [
    "Gestire auth o tenant isolation"
  ],
  "dependencies": [
    "User",
    "Xot"
  ],
  "qualityGates": [
    "./vendor/bin/phpstan analyse Modules/Notify",
    "./vendor/bin/phpinsights analyse Modules/Notify --min-quality=0 --min-complexity=0 --min-architecture=0 --min-style=0"
  ],
  "suiteVersion": "baseline-v1",
  "sourceFramework": "Notion product template family adapted to repository governance",
  "companionDocs": [
    "product-roadmap.md",
    "product-launch-plan.md",
    "product-strategy.md",
    "user-research.md",
    "sprint-planning-meeting.md"
  ],
  "implementationPattern": "action-first",
  "actionStandard": "spatie/laravel-queueable-action",
  "architectureRule": "No generic Services for business logic; use Action classes with execute()"
}
