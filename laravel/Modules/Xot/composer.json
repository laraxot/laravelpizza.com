{
    "name": "laraxot/module_xot_fila3",
    "description": "Base and core module for the Laraxot ecosystem: Filament wrappers, traits, base models, and shared utilities.",
    "keywords": [
        "laraxot",
        "laravel",
        "filament",
        "module_xot",
        "core",
        "base",
        "xot",
        "admin-panel"
    ],
    "homepage": "https://github.com/laraxot/module_xot_fila3",
    "license": "MIT",
    "authors": [
        {
            "name": "Marco Sottana",
            "email": "marco.sottana@gmail.com",
            "role": "Developer"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Xot\\Providers\\XotServiceProvider"
            ],
            "aliases": {
                "Xot" : "Modules\\Xot\\Facades\\Xot"
            }
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Xot\\": "app/",
            "Modules\\Xot\\Database\\Factories\\": "database/factories/",
            "Modules\\Xot\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Xot\\Tests\\": "tests/"
        }
    },
    "require": {
        "artesaos/laravel-two-factor-authentication": "^1.0",
        "awcodes/filament-badge-column": "^2.0",
        "awcodes/filament-curator": "^3.0",
        "awcodes/filament-form-with-sentry": "^3.0",
        "awcodes/filament-tiptap-editor": "^3.0",
        "barryvdh/laravel-debugbar": "^3.0",
        "blade-ui-kit/blade-icons": "^1.0",
        "bezhansalleh/filament-language-switch": "^3.0",
        "codebar-ag/laravel-livewire-toggle": "^1.0",
        "doctrine/dbal": "^3.0",
        "filament/filament": "^3.0",
        "filament/forms": "^3.0",
        "filament/notifications": "^3.0",
        "filament/tables": "^3.0",
        "filament/widgets": "^3.0",
        "flowbite/flowbite": "^1.0",
        "guzzlehttp/guzzle": "^7.0",
        "ibex/filament-multilanguage-forms": "^1.0",
        "laravel/framework": "^11.0",
        "livewire/livewire": "^3.0",
        "maatwebsite/excel": "^3.1",
        "nwidart/laravel-modules": "^10.0",
        "php": "^8.2",
        "pxlrbt/filament-clean-form": "^1.0",
        "ryangjchandler/filament-resource-views": "^1.0",
        "sokeio/filament-multi-language": "^3.0",
        "spatie/laravel-data": "^3.0",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-model-states": "^2.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-schemaless-attributes": "^3.0",
        "spatie/laravel-settings": "^3.0",
        "spatie/laravel-translatable": "^6.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^2.0",
        "larastan/larastan": "^2.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "./vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}