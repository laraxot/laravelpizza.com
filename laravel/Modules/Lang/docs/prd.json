{
  "name": "Lang",
  "type": "module",
  "status": "baseline",
  "purpose": "Gestire localizzazione, traduzioni e coerenza linguistica tra moduli e temi.",
  "goals": [
    "Stabilizzare la struttura delle traduzioni",
    "Supportare interfacce multilingua",
    "Ridurre drift e duplicazioni nelle chiavi"
  ],
  "nonGoals": [
    "Gestire il routing di dominio",
    "Sostituire Cms o Theme"
  ],
  "dependencies": [
    "Xot"
  ],
  "qualityGates": [
    "./vendor/bin/phpstan analyse Modules/Lang",
    "./vendor/bin/phpinsights analyse Modules/Lang --min-quality=0 --min-complexity=0 --min-architecture=0 --min-style=0"
  ],
  "suiteVersion": "baseline-v1",
  "sourceFramework": "Notion product template family adapted to repository governance",
  "companionDocs": [
    "product-roadmap.md",
    "product-launch-plan.md",
    "product-strategy.md",
    "user-research.md",
    "sprint-planning-meeting.md"
  ],
  "implementationPattern": "action-first",
  "actionStandard": "spatie/laravel-queueable-action",
  "architectureRule": "No generic Services for business logic; use Action classes with execute()"
}
