{
    "name": "laraxot/module_lang_fila5",
    "description": "Internationalization and localization module for the Laraxot ecosystem: translations, languages, and locale management.",
    "keywords": [
        "laraxot",
        "laravel",
        "filament",
        "module_lang",
        "lang",
        "i18n",
        "l10n",
        "translations",
        "localization"
    ],
    "license": "MIT",
    "homepage": "https://github.com/laraxot/module_lang_fila5.git",
    "authors": [
        {
            "name": "Marco Sottana",
            "email": "marco.sottana@gmail.com"
        }
    ],
    "require": {
        "mcamara/laravel-localization": "*",
        "lara-zeus/spatie-translatable": "*",
        "rinvex/countries": "^9.1",
        "spatie/laravel-sluggable": "*"
    },
    "require-comment": {
        
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Xot"
        },
        {
            "type": "path",
            "url": "../Tenant"
        },
        {
            "type": "path",
            "url": "../UI"
        }
        
    ],
    "repositories-comment": [
        {
            "type": "path",
            "url": "./packages/lara-zeus/spatie-translatable"
        },
        {
            "type": "composer",
            "url": "https://packagist.org",
            "canonical": false
        }
    ],
    "autoload": {
        "psr-4": {
            "Modules\\Lang\\": "app/",
            "Modules\\Lang\\Database\\Factories\\": "database/factories/",
            "Modules\\Lang\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Lang\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [],
        "post-update-cmd": [],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "./vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Lang\\Providers\\LangServiceProvider",
                "Modules\\Lang\\Providers\\Filament\\AdminPanelProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
