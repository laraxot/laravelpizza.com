{
  "name": "Geo",
  "type": "module",
  "status": "baseline",
  "purpose": "Fornire geolocalizzazione, mappe, calcoli di distanza e servizi geografici accessori.",
  "goals": [
    "Esporre servizi geo riusabili",
    "Supportare integrazioni con provider esterni",
    "Stabilizzare calcoli e action geografiche"
  ],
  "nonGoals": [
    "Gestire contenuti editoriali",
    "Gestire prediction markets"
  ],
  "dependencies": [
    "Xot"
  ],
  "qualityGates": [
    "./vendor/bin/phpstan analyse Modules/Geo",
    "./vendor/bin/phpinsights analyse Modules/Geo --min-quality=0 --min-complexity=0 --min-architecture=0 --min-style=0"
  ],
  "suiteVersion": "baseline-v1",
  "sourceFramework": "Notion product template family adapted to repository governance",
  "companionDocs": [
    "product-roadmap.md",
    "product-launch-plan.md",
    "product-strategy.md",
    "user-research.md",
    "sprint-planning-meeting.md"
  ],
  "implementationPattern": "action-first",
  "actionStandard": "spatie/laravel-queueable-action",
  "architectureRule": "No generic Services for business logic; use Action classes with execute()"
}
