{
  "name": "Media",
  "type": "module",
  "status": "baseline",
  "purpose": "Gestire upload, media library, conversioni e recupero asset per moduli e temi.",
  "goals": [
    "Centralizzare i flussi media",
    "Rendere affidabili conversioni e URL",
    "Servire immagini e asset riusabili"
  ],
  "nonGoals": [
    "Sostituire il tema",
    "Contenere business logic di contenuti"
  ],
  "dependencies": [
    "Xot"
  ],
  "qualityGates": [
    "./vendor/bin/phpstan analyse Modules/Media",
    "./vendor/bin/phpinsights analyse Modules/Media --min-quality=0 --min-complexity=0 --min-architecture=0 --min-style=0"
  ],
  "suiteVersion": "baseline-v1",
  "sourceFramework": "Notion product template family adapted to repository governance",
  "companionDocs": [
    "product-roadmap.md",
    "product-launch-plan.md",
    "product-strategy.md",
    "user-research.md",
    "sprint-planning-meeting.md"
  ],
  "implementationPattern": "action-first",
  "actionStandard": "spatie/laravel-queueable-action",
  "architectureRule": "No generic Services for business logic; use Action classes with execute()"
}
