{
  "name": "Tenant",
  "type": "module",
  "status": "baseline",
  "purpose": "Gestire isolamento tenant, configurazione tenant-aware e routing contestuale.",
  "goals": [
    "Mantenere isolamento e configurazione multi-tenant",
    "Ridurre leakage tra tenant",
